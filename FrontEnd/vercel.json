{
  "version": 2,
  "name": "vayu-frontend",
  "routes": [
    {
      "src": "/map",
      "dest": "/map.html"
    },
    {
      "src": "/research",
      "dest": "/research.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}