# ── Backend (Backend/.env) ─────────────────────────────────────────

# Port the Node.js server listens on locally
PORT=5000

# Set to production on Render (already set in render.yaml)
NODE_ENV=development

# URL of the Python ML service
# Local: http://localhost:5001
# Render: https://vayu-ml-service.onrender.com
ML_SERVICE_URL=http://localhost:5001

# URL of the frontend — used for CORS allow-list
# Render: set to your Vercel URL after deploying frontend
# FRONTEND_URL=https://vayu.vercel.app

# ── ML Service (ml_model/.env) ─────────────────────────────────────

# Port the Flask service listens on locally
# Must NOT conflict with the Node backend (which uses 5000)
ML_PORT=5001
